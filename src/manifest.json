{
  "manifest_version": 3,
  "name": "AO3 Academic Reader",
  "version": "1.3",
  "description": "Formats AO3 works into Academic or Wikipedia layouts.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AO3 Academic Reader"
  },
  "content_scripts": [
    {
      "matches": ["*://*.archiveofourown.org/works/*"],
      "css": ["academic-style.css", "wikipedia-style.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}